        <!-- Simplified sequence as labeled steps (lifelines without full UML messages - cleaner in drawio) -->
        <mxCell id="seq-note" parent="seq-box" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;fontSize=10;" value="&lt;b&gt;Paths&lt;/b&gt;: /chat · /mic · /audio/analyze → ask_question()&lt;br&gt;&lt;br&gt;&lt;b&gt;Step 0 — guardrails&lt;/b&gt; (always):&lt;br&gt;evaluate_user_message(user) → crisis | harmful | off_topic | allow&lt;br&gt;&lt;b&gt;Block&lt;/b&gt;: canned reply, append_turn only, skip summary + Groq main path&lt;br&gt;API: guardrail_triggered=true, guardrail_category; UI notifyGuardrail()&lt;br&gt;&lt;b&gt;Allow&lt;/b&gt;: ① RAG k=3 ② summary ③ history ④ LLM ⑤ append ⑥ summary if ≥5 turns&lt;br&gt;&lt;br&gt;&lt;b&gt;TTS&lt;/b&gt;: POST /tts (not run on guardrail block unless user plays refusal)" vertex="1">
          <mxGeometry x="1020" y="50" width="280" height="260" as="geometry" />
        </mxCell>
        <!-- Data models -->
        <mxCell id="dm-box" parent="1" style="swimlane;startSize=28;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" value="Data Models" vertex="1">
          <mxGeometry x="40" y="390" width="640" height="360" as="geometry" />
        </mxCell>
        <mxCell id="dm-session" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="Session (UI / localStorage)&lt;br&gt;—&lt;br&gt;id: string (UUID)&lt;br&gt;title: string&lt;br&gt;createdAt, updatedAt: number&lt;br&gt;messages: Msg[]&lt;br&gt;saved: boolean" vertex="1">
          <mxGeometry x="30" y="45" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="dm-msg" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="Msg (UI display)&lt;br&gt;—&lt;br&gt;id: number&lt;br&gt;role: &quot;user&quot; | &quot;ai&quot;&lt;br&gt;text: string&lt;br&gt;time: string" vertex="1">
          <mxGeometry x="240" y="45" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dm-turn" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="Turn (API / Redis)&lt;br&gt;—&lt;br&gt;user: string&lt;br&gt;bot: string" vertex="1">
          <mxGeometry x="430" y="45" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="dm-summary" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="SessionSummary (Redis JSON)&lt;br&gt;—&lt;br&gt;text: string&lt;br&gt;cursor: int  // turns summarized so far" vertex="1">
          <mxGeometry x="30" y="175" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="dm-chat-req" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="ChatRequest&lt;br&gt;message: string (min 1)" vertex="1">
          <mxGeometry x="280" y="175" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dm-mic-res" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#ffffff;fontSize=10;" value="MicChatResponse&lt;br&gt;+ guardrail_triggered, guardrail_category" vertex="1">
          <mxGeometry x="460" y="130" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="dm-guard" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="GuardrailResult&lt;br&gt;action: allow | block&lt;br&gt;category: in_scope | off_topic | crisis | harmful&lt;br&gt;reply: string (if block)" vertex="1">
          <mxGeometry x="30" y="265" width="240" height="75" as="geometry" />
        </mxCell>
        <mxCell id="dm-ask-out" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="AskOutcome&lt;br&gt;reply: string&lt;br&gt;guardrail_triggered: bool&lt;br&gt;guardrail_category: str | null" vertex="1">
          <mxGeometry x="290" y="250" width="200" height="75" as="geometry" />
        </mxCell>
        <mxCell id="dm-guard-meta" parent="dm-box" style="shape=umlClass;whiteSpace=wrap;html=1;fillColor=#dae8fc;fontSize=10;" value="GuardrailMeta (TS)&lt;br&gt;guardrail_triggered?: boolean&lt;br&gt;guardrail_category?: string | null" vertex="1">
          <mxGeometry x="510" y="200" width="120" height="70" as="geometry" />
        </mxCell>
        <!-- Summary algorithm -->
        <mxCell id="alg-box" parent="1" style="swimlane;startSize=28;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Algorithm: maybe_refresh_session_summary" vertex="1">
          <mxGeometry x="700" y="390" width="660" height="300" as="geometry" />
        </mxCell>
        <mxCell id="alg-start" parent="alg-box" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" value="Start" vertex="1">
          <mxGeometry x="40" y="50" width="60" height="40" as="geometry" />
        </mxCell>
        <mxCell id="alg-d1" parent="alg-box" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;" value="turn_count - cursor &amp;gt;= 5?" vertex="1">
          <mxGeometry x="150" y="40" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="alg-batch" parent="alg-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="get_turns_slice(cursor, 5)" vertex="1">
          <mxGeometry x="340" y="50" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="alg-merge" parent="alg-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;" value="merge_summarize_turn_batch(prior_summary, batch)" vertex="1">
          <mxGeometry x="530" y="50" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="alg-set" parent="alg-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" value="set_session_summary(text, cursor+5)" vertex="1">
          <mxGeometry x="340" y="120" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="alg-end" parent="alg-box" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;" value="End" vertex="1">
          <mxGeometry x="40" y="130" width="60" height="40" as="geometry" />
        </mxCell>
        <mxCell id="alg-env" parent="alg-box" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;" value="Env (conversation_store): REDIS_* · REDIS_DISABLED=1&lt;br&gt;Env (guardrails): SENSIA_GUARDRAILS_ENABLED (default 1) · SENSIA_CRISIS_REGION IN|US|UK&lt;br&gt;Skip summary refresh when guardrail_category == off_topic" vertex="1">
          <mxGeometry x="30" y="190" width="600" height="75" as="geometry" />
        </mxCell>
        <mxCell id="ae1" edge="1" parent="alg-box" source="alg-start" target="alg-d1" style="endArrow=classic;html=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae2" edge="1" parent="alg-box" source="alg-d1" target="alg-batch" style="endArrow=classic;html=1;" value="Yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae3" edge="1" parent="alg-box" source="alg-batch" target="alg-merge" style="endArrow=classic;html=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae4" edge="1" parent="alg-box" source="alg-merge" target="alg-set" style="endArrow=classic;html=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ae5" edge="1" parent="alg-box" source="alg-set" target="alg-d1" style="endArrow=classic;html=1;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="440" y="200" />
              <mxPoint x="220" y="200" />
              <mxPoint x="220" y="110" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ae6" edge="1" parent="alg-box" source="alg-d1" target="alg-end" style="endArrow=classic;html=1;" value="No">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Error handling -->
        <mxCell id="err-box" parent="1" style="swimlane;startSize=28;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" value="Cross-cutting (POC)" vertex="1">
          <mxGeometry x="40" y="770" width="1320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="err1" parent="err-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;align=center;fontSize=11;" value="CORS: localhost:8080, 5173, 3000" vertex="1">
          <mxGeometry x="30" y="40" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="err2" parent="err-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;align=center;fontSize=11;" value="Dedupe: SHA256 per session (mic + upload)" vertex="1">
          <mxGeometry x="250" y="40" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="err3" parent="err-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;align=center;fontSize=11;" value="TTS: ttsGenerationRef + single audio element" vertex="1">
          <mxGeometry x="490" y="40" width="220" height="45" as="geometry" />
        </mxCell>
        <mxCell id="err4" parent="err-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;align=center;fontSize=11;" value="Windows: sensia_bootstrap UTF-8" vertex="1">
          <mxGeometry x="730" y="40" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="err5" parent="err-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;align=center;fontSize=11;" value="HTTP 500: _safe_error_message()" vertex="1">
          <mxGeometry x="930" y="40" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="err6" parent="err-box" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;align=center;fontSize=11;" value="Guardrails: regex policy · no Groq on block" vertex="1">
          <mxGeometry x="1130" y="40" width="170" height="45" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
