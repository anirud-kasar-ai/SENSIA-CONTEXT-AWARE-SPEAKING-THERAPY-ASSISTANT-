# Copy to .env and fill in real values. Do not commit .env to git.

# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional LLM
GROQ_MODEL=llama-3.3-70b-versatile

# Redis (optional — in-memory fallback if unset/unreachable)
REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_SSL=0
# REDIS_KEY_PREFIX=sensia:chat:
# REDIS_SUMMARY_PREFIX=sensia:summary:
# REDIS_CHAT_TTL=
# REDIS_DISABLED=1

# Guardrails (enabled by default)
SENSIA_GUARDRAILS_ENABLED=1
SENSIA_CRISIS_REGION=IN
